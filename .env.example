# Landing Client Environment Variables

# Base domain for display purposes (e.g., "tu-tienda.DOMAIN")
VITE_BASE_DOMAIN=j-markets.jcampos.dev

# Full URL of the store app (including protocol)
# For localhost development:
VITE_APP_URL=http://localhost:9000

# For production:
# VITE_APP_URL=https://j-markets.jcampos.dev

# API URL for backend server
# For localhost development:
VITE_API_URL=http://localhost:5000

# For production:
# VITE_API_URL=https://markets-api.jcampos.dev
